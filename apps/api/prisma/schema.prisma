// apps/api/prisma/schema.prisma

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  STAFF
  TECHNICIAN
  CASHIER
}

enum CustomerType {
  NORMAL
  VIP
  WHOLESALE
  PARTNER
}

// Shared line-item type for sales, invoices, and carts
enum ItemType {
  SERVICE
  PRODUCT
  CUSTOM
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIAL
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  ABA
  BANK_TRANSFER
  CARD
  OTHER
}

enum SaleStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum PosCartStatus {
  ACTIVE
  CLOSED
}

enum QuotationStatus {
  DRAFT
  ISSUED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ExpenseCategory {
  SUPPLIES
  UTILITIES
  RENT
  SALARY
  MAINTENANCE
  OTHER
}

// Where the reference data came from
enum ReferenceSourceType {
  MOM_NOTEBOOK // handwritten notebook from experience
  SUPPLIER_INFO // from parts supplier
  REAL_MEASUREMENT // measured from actual part in shop
  SERVICE_HISTORY // derived from past service records
  SERVICE_MANUAL // official service manual
  OTHER
}

enum VerificationStatus {
  DRAFT
  PENDING_REVIEW
  VERIFIED
  OLD_DATA
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  CANCEL
  PAYMENT
  PRICE_CHANGE
  STOCK_CHANGE
  DISCOUNT
}

// ─────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(STAFF)
  isActive  Boolean  @default(true)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdSales    Sale[]
  createdInvoices Invoice[]
  payments        Payment[]
  expenses        Expense[]
  auditLogs       AuditLog[]
  posCarts        PosCart[]
  quotations      Quotation[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────────
// CUSTOMER
// ─────────────────────────────────────────────────────────────────

model Customer {
  id           String       @id @default(cuid())
  code         String       @unique // e.g. C-0001
  name         String
  phone        String
  imageUrl     String?
  customerType CustomerType @default(NORMAL)
  notes        String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  invoices   Invoice[]
  sales      Sale[]
  payments   Payment[]
  quotations Quotation[]

  @@index([phone])
  @@map("customers")
}

// ─────────────────────────────────────────────────────────────────
// SERVICE  (workshop service catalog)
// ─────────────────────────────────────────────────────────────────

model Service {
  id               String    @id @default(cuid())
  code             String    @unique // e.g. SRV-001
  nameEn           String
  nameKh           String?
  imageUrl         String?
  category         String? // e.g. "Cylinder Work", "Bearing Work"
  relatedComponent String? // e.g. "Cylinder", "Cylinder Head", "Piston"
  description      String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  priceCatalog PriceCatalog[]
  invoiceItems InvoiceItem[]
  saleItems    SaleItem[]
  cartItems    CartItem[]

  @@map("services")
}

// ─────────────────────────────────────────────────────────────────
// PRICE CATALOG
// Suggested service prices by machine/model.
// ─────────────────────────────────────────────────────────────────

model PriceCatalog {
  id             String    @id @default(cuid())
  serviceId      String
  machineModelId String
  label          String
  unitPrice      Decimal   @db.Decimal(12, 2)
  currency       String    @default("USD")
  notes          String?
  effectiveDate  DateTime  @default(now())
  expiredDate    DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  service      Service      @relation(fields: [serviceId], references: [id])
  machineModel MachineModel @relation(fields: [machineModelId], references: [id])

  @@index([serviceId])
  @@index([machineModelId])
  @@index([serviceId, machineModelId])
  @@map("price_catalogs")
}

// ─────────────────────────────────────────────────────────────────
// MACHINE MODEL
// Brand + model of the machine whose parts are brought in
// ─────────────────────────────────────────────────────────────────

model MachineModel {
  id          String    @id @default(cuid())
  brand       String // e.g. Honda, Kubota, Yanmar
  model       String // e.g. CB150, RT140
  category    String? // Engine, Generator, Pump, Compressor
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  priceCatalogs  PriceCatalog[]
  referenceBooks ReferenceBook[]
  posCarts       PosCart[]
  cartItems      CartItem[]
  sales          Sale[]
  saleItems      SaleItem[]
  invoiceItems   InvoiceItem[]

  @@unique([brand, model])
  @@index([brand])
  @@map("machine_models")
}

// ─────────────────────────────────────────────────────────────────
// REFERENCE BOOK
// Standard measurements for parts — may or may not be tied to a specific machine model
// ─────────────────────────────────────────────────────────────────

model ReferenceBook {
  id                 String              @id @default(cuid())
  machineModelId     String? // optional — generic part specs have no model
  componentType      String? // e.g. "Cylinder", "Piston", "Crankshaft"
  partName           String // e.g. "Standard Bore – Honda CB150"
  partCode           String?
  standardSize       Decimal?            @db.Decimal(10, 3) // factory spec
  wearLimit          Decimal?            @db.Decimal(10, 3) // minimum acceptable
  serviceLimit       Decimal?            @db.Decimal(10, 3) // service threshold
  unit               String              @default("mm")
  measurementDetails Json? // flexible extra measurements as JSON
  sourceType         ReferenceSourceType @default(OTHER)
  verificationStatus VerificationStatus  @default(DRAFT)
  notes              String?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  machineModel   MachineModel? @relation(fields: [machineModelId], references: [id])
  linkedProducts Product[]

  @@index([machineModelId])
  @@index([componentType])
  @@map("reference_books")
}

// ─────────────────────────────────────────────────────────────────
// PRODUCT  (inventory)
// ─────────────────────────────────────────────────────────────────

model Product {
  id                    String    @id @default(cuid())
  code                  String    @unique // e.g. PRD-001
  name                  String
  nameKh                String?
  nameEn                String?
  aliases               String?
  imageUrl              String?
  brand                 String?
  componentPartType     String? // e.g. "Piston Ring", "Bearing", "Gasket"
  size                  String? // e.g. "65.00 mm", "1/2 inch"
  supplier              String?
  description           String?
  category              String?
  unit                  String    @default("piece")
  costPrice             Decimal   @db.Decimal(12, 2)
  sellingPrice          Decimal   @db.Decimal(12, 2)
  stockQuantity         Int       @default(0)
  reorderLevel          Int       @default(0)
  linkedReferenceBookId String?
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  linkedReferenceBook ReferenceBook? @relation(fields: [linkedReferenceBookId], references: [id])
  saleItems           SaleItem[]
  invoiceItems        InvoiceItem[]
  cartItems           CartItem[]

  @@index([componentPartType])
  @@map("products")
}

// ─────────────────────────────────────────────────────────────────
// INVOICE
// ─────────────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique // e.g. INV-2024-0001
  customerId     String
  saleId         String? // linked Sale, if any
  status         InvoiceStatus @default(DRAFT)
  subtotal       Decimal       @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal       @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(12, 2)
  dueAmount      Decimal       @db.Decimal(12, 2)
  notes          String?
  issuedAt       DateTime      @default(now())
  dueDate        DateTime?
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  customer  Customer      @relation(fields: [customerId], references: [id])
  sale      Sale?         @relation(fields: [saleId], references: [id])
  createdBy User          @relation(fields: [createdById], references: [id])
  items     InvoiceItem[]
  payments  Payment[]

  @@index([customerId])
  @@index([status])
  @@map("invoices")
}

// ─────────────────────────────────────────────────────────────────
// INVOICE ITEM
// ─────────────────────────────────────────────────────────────────

model InvoiceItem {
  id                String   @id @default(cuid())
  invoiceId         String
  type              ItemType @default(SERVICE)
  serviceId         String?
  productId         String?
  machineModelId    String?
  modelNameSnapshot String?
  description       String
  itemCode          String?
  itemNameKh        String?
  itemNameEn        String?
  quantity          Decimal  @default(1) @db.Decimal(10, 3)
  unitPrice         Decimal  @db.Decimal(12, 2)
  discountAmount    Decimal  @default(0) @db.Decimal(12, 2)
  totalPrice        Decimal  @db.Decimal(12, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  invoice      Invoice       @relation(fields: [invoiceId], references: [id])
  service      Service?      @relation(fields: [serviceId], references: [id])
  product      Product?      @relation(fields: [productId], references: [id])
  machineModel MachineModel? @relation(fields: [machineModelId], references: [id])

  @@index([invoiceId])
  @@index([machineModelId])
  @@map("invoice_items")
}

// ─────────────────────────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────────────────────────

model Payment {
  id            String        @id @default(cuid())
  paymentNumber String        @unique // e.g. PAY-2024-0001
  invoiceId     String
  customerId    String
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod @default(CASH)
  referenceNo   String? // ABA ref, bank transfer ref, etc.
  notes         String?
  paidAt        DateTime      @default(now())
  createdById   String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  customer  Customer @relation(fields: [customerId], references: [id])
  createdBy User     @relation(fields: [createdById], references: [id])

  @@index([invoiceId])
  @@index([customerId])
  @@map("payments")
}

// ─────────────────────────────────────────────────────────────────
// SALE  (completed checkout record from cart)
// ─────────────────────────────────────────────────────────────────

model Sale {
  id                String     @id @default(cuid())
  saleNumber        String     @unique // e.g. SALE-2024-0001
  customerId        String? // optional — walk-in sale
  machineModelId    String?
  modelNameSnapshot String?
  customerName      String     @default("Walk-in Customer")
  status            SaleStatus @default(COMPLETED)
  subtotal          Decimal    @db.Decimal(12, 2)
  discountAmount    Decimal    @default(0) @db.Decimal(12, 2)
  totalAmount       Decimal    @db.Decimal(12, 2)
  notes             String?
  soldAt            DateTime   @default(now())
  createdById       String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  customer     Customer?     @relation(fields: [customerId], references: [id])
  machineModel MachineModel? @relation(fields: [machineModelId], references: [id])
  createdBy    User          @relation(fields: [createdById], references: [id])
  items        SaleItem[]
  invoices     Invoice[]

  @@index([customerId])
  @@index([machineModelId])
  @@map("sales")
}

// ─────────────────────────────────────────────────────────────────
// SALE ITEM
// ─────────────────────────────────────────────────────────────────

model SaleItem {
  id                String   @id @default(cuid())
  saleId            String
  type              ItemType @default(PRODUCT)
  serviceId         String?
  productId         String?
  machineModelId    String?
  modelNameSnapshot String?
  itemCode          String?
  itemNameKh        String?
  itemNameEn        String?
  description       String
  quantity          Decimal  @default(1) @db.Decimal(10, 3)
  unitPrice         Decimal  @db.Decimal(12, 2)
  discountAmount    Decimal  @default(0) @db.Decimal(12, 2)
  totalPrice        Decimal  @db.Decimal(12, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  sale         Sale          @relation(fields: [saleId], references: [id])
  service      Service?      @relation(fields: [serviceId], references: [id])
  product      Product?      @relation(fields: [productId], references: [id])
  machineModel MachineModel? @relation(fields: [machineModelId], references: [id])

  @@index([saleId])
  @@index([machineModelId])
  @@map("sale_items")
}

// ─────────────────────────────────────────────────────────────────
// EXPENSE
// ─────────────────────────────────────────────────────────────────

model Expense {
  id            String          @id @default(cuid())
  expenseNumber String          @unique // e.g. EXP-2024-0001
  category      ExpenseCategory @default(OTHER)
  description   String
  amount        Decimal         @db.Decimal(12, 2)
  method        PaymentMethod   @default(CASH)
  referenceNo   String?
  notes         String?
  expenseDate   DateTime        @default(now())
  createdById   String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  createdBy User @relation(fields: [createdById], references: [id])

  @@index([category])
  @@index([expenseDate])
  @@map("expenses")
}

// ─────────────────────────────────────────────────────────────────
// AUDIT LOG  (immutable — no updatedAt)
// ─────────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  entityType String // "Customer", "Invoice", etc.
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────
// SETTING  (flexible key-value configuration store)
// ─────────────────────────────────────────────────────────────────

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String?
  type        String   @default("text")
  group       String   @default("general")
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([group])
  @@map("settings")
}

// ─────────────────────────────────────────────────────────────────
// QUOTATION  (price estimate — does NOT reduce stock or create revenue)
// ─────────────────────────────────────────────────────────────────

model Quotation {
  id              String          @id @default(cuid())
  quotationNumber String          @unique // e.g. QUOT-2024-0001
  customerId      String?
  customerName    String          @default("Walk-in Customer")
  customerPhone   String          @default("")
  status          QuotationStatus @default(ISSUED)
  items           Json            @default("[]")
  subtotal        Decimal         @db.Decimal(12, 2)
  discountAmount  Decimal         @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal         @db.Decimal(12, 2)
  notes           String?
  validUntil      DateTime?
  posCartId       String? // the cart that created this quotation
  createdById     String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  customer  Customer? @relation(fields: [customerId], references: [id])
  createdBy User      @relation(fields: [createdById], references: [id])

  @@index([customerId])
  @@map("quotations")
}

// ─────────────────────────────────────────────────────────────────
// POS CART  (server-side draft cart for POS sale panel)
// Items stored in CartItem table; never auto-converts to Invoice/Payment
// ─────────────────────────────────────────────────────────────────

model PosCart {
  id                String        @id @default(cuid())
  cartCode          String        @unique // e.g. CART-001
  cartName          String        @default("New Cart")
  customerId        String?
  machineModelId    String?
  modelNameSnapshot String?
  customerName      String        @default("Walk-in Customer")
  customerPhone     String        @default("")
  jobTitle          String?
  engineType        String?
  discountAmount    Decimal       @default(0) @db.Decimal(12, 2)
  paidAmount        Decimal       @default(0) @db.Decimal(12, 2)
  paymentMethod     PaymentMethod @default(CASH)
  note              String?
  internalNote      String?
  status            PosCartStatus @default(ACTIVE)
  createdById       String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  createdBy    User          @relation(fields: [createdById], references: [id])
  machineModel MachineModel? @relation(fields: [machineModelId], references: [id])
  items        CartItem[]

  @@index([createdById])
  @@index([machineModelId])
  @@index([status])
  @@map("pos_carts")
}

// ─────────────────────────────────────────────────────────────────
// CART ITEM  (line items for a draft POS cart)
// Deleted automatically when Cart is deleted (Cascade)
// ─────────────────────────────────────────────────────────────────

model CartItem {
  id                String   @id @default(cuid())
  cartId            String
  type              ItemType
  serviceId         String?
  productId         String?
  machineModelId    String?
  modelNameSnapshot String?
  itemCode          String?
  itemNameKh        String?
  itemNameEn        String?
  description       String?
  quantity          Decimal  @default(1) @db.Decimal(10, 3)
  unitPrice         Decimal  @default(0) @db.Decimal(12, 2)
  discountAmount    Decimal  @default(0) @db.Decimal(12, 2)
  totalPrice        Decimal  @default(0) @db.Decimal(12, 2)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  cart         PosCart       @relation(fields: [cartId], references: [id], onDelete: Cascade)
  service      Service?      @relation(fields: [serviceId], references: [id])
  product      Product?      @relation(fields: [productId], references: [id])
  machineModel MachineModel? @relation(fields: [machineModelId], references: [id])

  @@index([cartId])
  @@index([serviceId])
  @@index([productId])
  @@index([machineModelId])
  @@map("cart_items")
}
