# ─────────────────────────────────────────────────────────────────
# DATABASE
# Use a standard PostgreSQL connection string.
# @prisma/adapter-pg requires the postgresql:// format.
# Do NOT use prisma+postgres:// here — that format is incompatible
# with the pg driver adapter.
# ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/workshop_db"

# ─────────────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────────────
PORT=4000

# ─────────────────────────────────────────────────────────────────
# JWT  (required for auth — Foundation Step 2)
# Generate a strong random secret before deploying.
# ─────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
