# ─────────────────────────────────────────────────────────────────
# DATABASE
# Use a standard PostgreSQL connection string.
# @prisma/adapter-pg requires the postgresql:// format.
# Do NOT use prisma+postgres:// — that format is incompatible
# with the pg driver adapter.
# ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/workshop_db"

# ─────────────────────────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# Frontend origin allowed by CORS. Update for production.
CORS_ORIGIN=http://localhost:3000

# ─────────────────────────────────────────────────────────────────
# JWT  (required for auth — Foundation Step 3)
# Generate a strong random secret before deploying:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
